{
    "name": "ROS 2 Development Container",
    "privileged": true,
    "remoteUser": "developer",
    "updateRemoteUserUID": true,
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "developer"
        }
    },
    "workspaceFolder": "/home/ws",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/ws/src/soar_ros/,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "twxs.cmake",
                "ranch-hand-robotics.rde-ros-2",
                "ms-toolsai.jupyter",
                "github.copilot-chat",
                "zachflower.uncrustify"
            ]
        }
    },
    "containerEnv": {
        "DISPLAY": "unix:0",
        "ROS_AUTOMATIC_DISCOVERY_RANGE": "LOCALHOST",
        "ROS_DOMAIN_ID": "42"
    },
    "runArgs": [
        "--net=host",
        "--pid=host",
        "--ipc=host",
        "-e",
        "DISPLAY=${env:DISPLAY}"
    ],
    "postCreateCommand": "sudo apt-get update && sudo rosdep update && sudo rosdep install --from-paths src --ignore-src -y",
    "postAttachCommand": "colcon build --symlink-install --event-handlers console_cohesion+ --base-paths /home/ws --cmake-args -DCMAKE_BUILD_TYPE=RelWithDebInfo"
}